## Example environment variables
# Set DB_DRIVER to 'pgsql' for Supabase, or 'mysql' for MySQL
DB_DRIVER=pgsql
DB_HOST=your-db-host.supabase.co
DB_HOSTADDR=1.2.3.4
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=yourpassword
DB_SSLMODE=require
APP_ENCRYPTION_KEY=change-this-to-a-long-random-secret

# Optional: Set recommended PHP timezone
APP_TIMEZONE=Asia/Kuala_Lumpur
